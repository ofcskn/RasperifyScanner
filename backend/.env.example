# AI Providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PRIMARY_PROVIDER=gemini
AI_RETRY_MAX=3
AI_RETRY_BACKOFF_BASE=2.0

# JWT Auth
SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin user created on first startup (leave blank to skip)
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=change_this_password

# Database
DATABASE_URL=sqlite+aiosqlite:///./rasperify.db

# Camera
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720
CAMERA_FRAME_QUEUE_SIZE=10
CAMERA_MOCK=false

# Analysis
ANALYSIS_WORKER_COUNT=2
ANALYSIS_DEFAULT_INTERVAL_SECONDS=30

# Network (read from config/network.yml)
NETWORK_CONFIG_PATH=../config/network.yml
